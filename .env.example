# =========================================
# Franchise Management API - Environment Variables
# Para Render.com
# =========================================

# ===== BASE DE DATOS (PostgreSQL) =====
# Formato R2DBC: r2dbc:postgresql://HOST:PORT/DATABASE
# Obtener de Render Dashboard → PostgreSQL Database → Connection String
SPRING_R2DBC_URL=r2dbc:postgresql://dpg-xxxxx-xxxxx.oregon-postgres.render.com:5432/franchisedb
SPRING_R2DBC_USERNAME=franchiseuser
SPRING_R2DBC_PASSWORD=your_password_here

# ===== SPRING BOOT CONFIGURATION =====
SPRING_PROFILES_ACTIVE=production
SERVER_PORT=8080

# ===== LOGGING =====
# Nivel de logs (DEBUG, INFO, WARN, ERROR)
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_IO_R2DBC=INFO
LOGGING_LEVEL_ORG_SPRINGFRAMEWORK_DATA_R2DBC=INFO
LOGGING_LEVEL_ORG_SPRINGFRAMEWORK_R2DBC=INFO

# ===== SWAGGER/OPENAPI =====
# Habilitar o deshabilitar Swagger UI en producción
SPRINGDOC_SWAGGER_UI_ENABLED=true
SPRINGDOC_API_DOCS_PATH=/api-docs
SPRINGDOC_SWAGGER_UI_PATH=/swagger-ui.html

# ===== DOCKER COMPOSE =====
# Deshabilitar en producción (solo para desarrollo local)
SPRING_DOCKER_COMPOSE_ENABLED=false

# ===== ACTUATOR =====
# Endpoints de salud y métricas
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info,metrics
MANAGEMENT_ENDPOINT_HEALTH_SHOW_DETAILS=when_authorized