# AWS Configuration
aws_region  = "us-east-1"
environment = "dev"

# VPC Configuration
vpc_cidr             = "10.0.0.0/16"
availability_zones   = ["us-east-1a", "us-east-1b"]
private_subnet_cidrs = ["10.0.1.0/24", "10.0.2.0/24"]
public_subnet_cidrs  = ["10.0.101.0/24", "10.0.102.0/24"]

# RDS Configuration
db_name              = "franchisedb"
db_username          = "admin"
db_password          = "CHANGE_ME_SECURE_PASSWORD"  # Store in AWS Secrets Manager or use environment variables
db_instance_class    = "db.t3.micro"
db_allocated_storage = 20
backup_retention_period = 7

# ECS Configuration
container_image   = "123456789012.dkr.ecr.us-east-1.amazonaws.com/franchise-management-api:latest"
container_port    = 8080
ecs_task_cpu      = 512
ecs_task_memory   = 1024
ecs_desired_count = 2

# Monitoring
alarm_email = "devops@example.com"